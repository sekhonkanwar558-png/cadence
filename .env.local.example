# Copy this file to .env.local and fill in the values.
# See the Day 1 plan's "External setup checklist" for where each comes from.

# Google AI Studio -> API key
GEMINI_API_KEY=

# Google Cloud Console -> Credentials -> OAuth client ID (Web application)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Run: openssl rand -base64 32   (any long random string works)
NEXTAUTH_SECRET=

# Base URL of the app (dev)
NEXTAUTH_URL=http://localhost:3000
